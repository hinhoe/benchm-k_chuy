<?xml version="1.0" encoding="utf-8"?>

<UserControl

    x:Class="Algorithm_Benchmark_Tool.AnalyticsChartControl"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d">



    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <TextBlock 

            Grid.Row="0"

            Text="Phân tích thời gian thực" 

            Foreground="white" 

            FontSize="24" 

            FontWeight="Bold" 

            VerticalAlignment="Center"

            HorizontalAlignment="Left"

            Margin="0,0,0,10"

        />



        <Grid Grid.Row="1" ColumnSpacing="20">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>



            <Border Grid.Column="0" Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1" Padding="15">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="100"/>

                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,10" Text="Thời gian thực thi" Foreground="#94a3b8" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left"/>

                    <Border Grid.Row="1" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Background="#10131a" Padding="10,5">

                        <Grid x:Name="TimeChartGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="TimeChartGrid_SizeChanged">

                            <Grid.RowDefinitions>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                            </Grid.RowDefinitions>



                            <Grid Grid.Row="0">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="45"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Bubble" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="TimeBarBubble" Grid.Column="1" Fill="#3b82f6" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TimeTextBubble" Grid.Column="2" Text="0.00 s" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="1">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="45"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Insertion" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="TimeBarInsertion" Grid.Column="1" Fill="#8b5cf6" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TimeTextInsertion" Grid.Column="2" Text="0.00 s" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="2">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="45"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Quick" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="TimeBarQuick" Grid.Column="1" Fill="#22c55e" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TimeTextQuick" Grid.Column="2" Text="0.00 s" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="3">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="45"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Merge" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="TimeBarMerge" Grid.Column="1" Fill="#facc15" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TimeTextMerge" Grid.Column="2" Text="0.00 s" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="4">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="45"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Shell" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="TimeBarShell" Grid.Column="1" Fill="red" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TimeTextShell" Grid.Column="2" Text="0.00 s" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                        </Grid>

                    </Border>

                </Grid>

            </Border>



            <Border Grid.Column="1" Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1" Padding="15">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="100"/>

                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,10" Text="Số lần hoán đổi" Foreground="#94a3b8" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left"/>

                    <Border Grid.Row="1" BorderBrush="#30363D" BorderThickness="1" CornerRadius="4" Background="#10131a" Padding="10,5">

                        <Grid x:Name="BarChartGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="BarChartGrid_SizeChanged">

                            <Grid.RowDefinitions>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                                <RowDefinition Height="*"/>

                            </Grid.RowDefinitions>



                            <Grid Grid.Row="0">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="35"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Bubble" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="BarBubble" Grid.Column="1" Fill="#3b82f6" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TextBubble" Grid.Column="2" Text="0" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="1">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="35"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Insertion" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="BarInsertion" Grid.Column="1" Fill="#8b5cf6" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TextInsertion" Grid.Column="2" Text="0" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="2">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="35"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Quick" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="BarQuick" Grid.Column="1" Fill="#22c55e" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TextQuick" Grid.Column="2" Text="0" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="3">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="35"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Merge" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="BarMerge" Grid.Column="1" Fill="#facc15" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TextMerge" Grid.Column="2" Text="0" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                            <Grid Grid.Row="4">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="80"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="35"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Shell" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>

                                <Rectangle x:Name="BarShell" Grid.Column="1" Fill="red" Height="8" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3"/>

                                <TextBlock x:Name="TextShell" Grid.Column="2" Text="0" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            </Grid>

                        </Grid>

                    </Border>

                </Grid>

            </Border>

        </Grid>



        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0, 5, 0, 0">

            <Ellipse Width="12" Height="12" Fill="#3b82f6" />

            <TextBlock Text="Bubble Sort" VerticalAlignment="Center" Margin="0, 0, 5, 0"/>

            <Ellipse Width="12" Height="12" Fill="#8b5cf6" />

            <TextBlock Text="Insertion Sort" VerticalAlignment="Center" Margin="0, 0, 5, 0"/>

            <Ellipse Width="12" Height="12" Fill="#22c55e" />

            <TextBlock Text="Quick Sort" VerticalAlignment="Center" Margin="0, 0, 5, 0"/>

            <Ellipse Width="12" Height="12" Fill="#facc15" />

            <TextBlock Text="Merge Sort" VerticalAlignment="Center" Margin="0, 0, 5, 0"/>

            <Ellipse Width="12" Height="12" Fill="red" />

            <TextBlock Text="Shell Sort" VerticalAlignment="Center" Margin="0, 0, 5, 0"/>

        </StackPanel>

    </Grid>

</UserControl>