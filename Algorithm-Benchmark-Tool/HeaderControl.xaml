<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Algorithm_Benchmark_Tool.HeaderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Algorithm_Benchmark_Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border BorderThickness="0, 0, 0, 1" BorderBrush="#363941 " Padding="20,10,10,15">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
        <Grid.ColumnDefinitions >
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" 
                       Text="AlgoBench v1.0" 
                       Foreground="#adc6ff" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="0,0,20,0"
                       VerticalAlignment="Center"
                       />
            <TextBlock Grid.Column="1" 
                       Text="So sánh hiệu năng thuật toán sắp xếp" 
                       Foreground="#94a3b8" 
                       FontSize="14" 
                       FontWeight="Normal"
                       VerticalAlignment="Center"
                       />
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10" Margin="40, 0, 0, 0">

                <RepeatButton x:Name="btnBack" Click="btnBack_Click" Margin="0,0,10,0" Background="#88d8b0" BorderBrush="#30363d" Delay="200" Interval="1">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <SymbolIcon Symbol="Previous" />
                        <TextBlock Text="Back" VerticalAlignment="Center"/>
                    </StackPanel>
                </RepeatButton>

                <RepeatButton x:Name="btnStep" Click="btnStep_Click" Margin="0,0,10,0" Background="#88d8b0" BorderBrush="#30363d" Delay="200" Interval="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Next  " Margin=    "5,0,0,0"/>
                        <SymbolIcon Symbol="Next"/>
                    </StackPanel>
                </RepeatButton>
                
                <Button Background="#adc6ff" Foreground="#003262" CornerRadius="6" Padding="12,6"  x:Name="btnStart" Click="btnStart_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Play"/>
                        <TextBlock Text="Start" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Background="Transparent" BorderBrush="#363941" BorderThickness="1" CornerRadius="6" Padding="12,6" Foreground="#c9d1d9"  x:Name="btnPause" Click="btnPause_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Pause"/>
                        <TextBlock Text="Pause" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Background="Transparent" BorderBrush="#363941" BorderThickness="1" CornerRadius="6" Padding="12,6" Foreground="#c9d1d9"  x:Name="btnStop" Click="btnStop_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh"/>
                        <TextBlock Text="Reset" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
